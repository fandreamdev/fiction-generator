enum WorldSettingCategory {
  /// 地点
  LOCATION @map("location")
  /// 组织
  ORGANIZATION @map("organization")
  /// 力量体系
  POWER_SYSTEM @map("power_system")
  /// 物品
  ITEM @map("item")
  /// 规则
  RULE @map("rule")
  /// 历史
  HISTORY @map("history")
  /// 其他
  OTHER @map("other")

  @@map("world_setting_category")
}

enum WorldSettingSourceType {
  /// 手动创建
  MANUAL @map("manual")
  /// 导入抽取
  IMPORTED @map("imported")
  /// AI 生成
  AI @map("ai")

  @@map("world_setting_source_type")
}

model WorldSetting {
  /// 主键
  id Int @id @default(autoincrement())
  /// 所属用户主键
  userId Int @map("user_id")
  /// 所属原作或世界观主键
  fandomId Int @map("fandom_id")
  /// 所属小说主键，可为空表示原作级设定
  novelId Int? @map("novel_id")
  /// 设定分类：location/organization/power_system/item/rule/history/other
  category WorldSettingCategory
  /// 设定名称
  name String @db.VarChar(128)
  /// 设定描述
  description String?
  /// 规则说明
  rules String?
  /// 备注
  notes String?
  /// 来源类型：manual/imported/ai
  sourceType WorldSettingSourceType @map("source_type")

  /// 删除标识
  deletedFlag Boolean @default(false) @map("deleted_flag")
  /// 创建时间
  createdAt DateTime @db.Timestamptz(3) @default(now()) @map("created_at")
  /// 更新时间
  updatedAt DateTime @updatedAt @db.Timestamptz(3) @map("updated_at")

  /// 所属用户
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// 所属原作或世界观
  fandom Fandom @relation(fields: [fandomId], references: [id], onDelete: Cascade)
  /// 所属小说
  novel Novel? @relation(fields: [novelId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([fandomId])
  @@index([novelId])
  @@map("world_settings")
}
