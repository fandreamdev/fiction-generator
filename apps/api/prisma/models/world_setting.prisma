model WorldSetting {
  /// 主键
  id BigInt @id @default(autoincrement())
  /// 所属用户主键
  userId BigInt @map("user_id")
  /// 所属原作或世界观主键
  fandomId BigInt @map("fandom_id")
  /// 所属小说主键，可为空表示原作级设定
  novelId BigInt? @map("novel_id")
  /// 设定分类：location/organization/power_system/item/rule/history/other
  category String @db.VarChar(32)
  /// 设定名称
  name String @db.VarChar(128)
  /// 设定描述
  description String?
  /// 规则说明
  rules String?
  /// 备注
  notes String?
  /// 来源类型：manual/imported/ai
  sourceType String @db.VarChar(16) @map("source_type")

  /// 删除标识
  deletedFlag Boolean @default(false) @map("deleted_flag")
  /// 创建时间
  createAt DateTime @db.Timestamptz(3) @default(now()) @map("create_at")
  /// 更新时间
  updateAt DateTime @updatedAt @db.Timestamptz(3) @map("update_at")

  @@index([userId])
  @@index([fandomId])
  @@index([novelId])
  @@map("world_settings")
}
