enum ImportedChapterStatus {
  /// 等待处理
  PENDING @map("pending")
  /// 已摘要
  SUMMARIZED @map("summarized")
  /// 已失败
  FAILED @map("failed")

  @@map("imported_chapter_status")
}

model ImportedChapter {
  /// 主键
  id BigInt @id @default(autoincrement())
  /// 所属导入任务主键
  importTaskId BigInt @map("import_task_id")
  /// 所属原作或世界观主键
  fandomId BigInt @map("fandom_id")
  /// 导入章节序号
  chapterNo Int @map("chapter_no")
  /// 导入章节标题
  title String? @db.VarChar(256)
  /// 导入章节正文
  content String?
  /// 导入章节摘要
  summary String?
  /// 字数
  wordCount Int? @map("word_count")
  /// 处理状态：pending/summarized/failed
  status ImportedChapterStatus

  /// 删除标识
  deletedFlag Boolean @default(false) @map("deleted_flag")
  /// 创建时间
  createdAt DateTime @db.Timestamptz(3) @default(now()) @map("created_at")
  /// 更新时间
  updatedAt DateTime @updatedAt @db.Timestamptz(3) @map("updated_at")

  /// 所属导入任务
  importTask ImportTask @relation(fields: [importTaskId], references: [id], onDelete: Cascade)
  /// 所属原作或世界观
  fandom Fandom @relation(fields: [fandomId], references: [id], onDelete: Cascade)
  /// 基于该导入章节抽取出的候选项
  extractionCandidates ExtractionCandidate[]

  @@unique([importTaskId, chapterNo])
  @@index([importTaskId])
  @@index([fandomId])
  @@map("imported_chapters")
}
