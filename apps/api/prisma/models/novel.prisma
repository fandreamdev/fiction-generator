enum NovelType {
  /// 同人小说
  FANFIC @map("fanfic")
  /// 原创小说
  ORIGINAL @map("original")

  @@map("novel_type")
}

enum NovelFanficType {
  /// 原作线
  CANON @map("canon")
  /// IF 线
  IF @map("if")
  /// 重生
  REBIRTH @map("rebirth")
  /// 穿越
  TRANSMIGRATION @map("transmigration")
  /// 现代 AU
  MODERN_AU @map("modern_au")
  /// 架空 AU
  AU @map("au")
  /// 后续篇
  SEQUEL @map("sequel")

  @@map("novel_fanfic_type")
}

enum NovelStatus {
  /// 草稿
  DRAFT @map("draft")
  /// 写作中
  WRITING @map("writing")
  /// 已完结
  FINISHED @map("finished")

  @@map("novel_status")
}

model Novel {
  /// 主键
  id Int @id @default(autoincrement())
  /// 所属用户主键
  userId Int @map("user_id")
  /// 所属原作或世界观主键，原创作品可为空
  fandomId Int? @map("fandom_id")
  /// 小说标题
  title String @db.VarChar(128)
  /// 小说类型：fanfic/original
  type NovelType
  /// 同人类型：canon/if/rebirth/transmigration/modern_au/au/sequel
  fanficType NovelFanficType? @map("fanfic_type")
  /// 小说简介
  description String?
  /// 分歧点说明
  divergencePoint String? @map("divergence_point")
  /// 整体基调
  tone String? @db.VarChar(64)
  /// 写作状态：draft/writing/finished
  status NovelStatus

  /// 删除标识
  deletedFlag Boolean @default(false) @map("deleted_flag")
  /// 创建时间
  createdAt DateTime @db.Timestamptz(3) @default(now()) @map("created_at")
  /// 更新时间
  updatedAt DateTime @updatedAt @db.Timestamptz(3) @map("updated_at")

  /// 所属用户
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// 所属原作或世界观
  fandom Fandom? @relation(fields: [fandomId], references: [id], onDelete: SetNull)
  /// 小说关联的人物设定
  characters Character[]
  /// 小说关联的世界设定
  worldSettings WorldSetting[]
  /// 小说分卷
  volumes Volume[]
  /// 小说章节
  chapters Chapter[]
  /// 小说写作风格
  writingStyles WritingStyle[]
  /// 小说向量文档
  vectorDocuments VectorDocument[]
  /// 小说生成任务
  generationTasks GenerationTask[]

  @@index([userId])
  @@index([fandomId])
  @@map("novels")
}
