model User {
  /// 主键
  id Int @id @default(autoincrement())
  /// 邮箱，登录账号
  email String @db.VarChar(128) @unique
  /// 加密后的密码，bcrypt cost=12
  passwordHash String @db.VarChar(255) @map("password_hash")
  /// 显示名称
  nickname String @db.VarChar(64) @default("小说家")
  
  /// 删除标识
  deletedFlag Boolean @default(false) @map("deleted_flag")
  /// 创建时间
  createdAt DateTime @db.Timestamptz(3) @default(now()) @map("created_at")
  /// 更新时间
  updatedAt DateTime @updatedAt @db.Timestamptz(3) @map("updated_at")

  /// 用户创建的原作或世界观
  fandoms Fandom[]
  /// 用户创建的小说
  novels Novel[]
  /// 用户发起的导入任务
  importTasks ImportTask[]
  /// 用户的抽取候选项
  extractionCandidates ExtractionCandidate[]
  /// 用户的人物设定
  characters Character[]
  /// 用户的世界设定
  worldSettings WorldSetting[]
  /// 用户的写作风格
  writingStyles WritingStyle[]
  /// 用户的向量文档
  vectorDocuments VectorDocument[]
  /// 用户的生成任务
  generationTasks GenerationTask[]

  @@map("users")
}
