model Volume {
  /// 主键
  id BigInt @id @default(autoincrement())
  /// 所属小说主键
  novelId BigInt @map("novel_id")
  /// 分卷标题
  title String @db.VarChar(128)
  /// 分卷排序序号
  orderIndex Int @map("order_index")
  /// 分卷摘要
  summary String?

  /// 删除标识
  deletedFlag Boolean @default(false) @map("deleted_flag")
  /// 创建时间
  createdAt DateTime @db.Timestamptz(3) @default(now()) @map("created_at")
  /// 更新时间
  updatedAt DateTime @updatedAt @db.Timestamptz(3) @map("updated_at")

  /// 所属小说
  novel Novel @relation(fields: [novelId], references: [id], onDelete: Cascade)
  /// 分卷章节
  chapters Chapter[]

  @@unique([novelId, orderIndex])
  @@index([novelId])
  @@map("volumes")
}
