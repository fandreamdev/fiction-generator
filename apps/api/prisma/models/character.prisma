model Character {
  /// 主键
  id BigInt @id @default(autoincrement())
  /// 所属用户主键
  userId BigInt @map("user_id")
  /// 所属原作或世界观主键
  fandomId BigInt @map("fandom_id")
  /// 所属小说主键，可为空表示原作级人物
  novelId BigInt? @map("novel_id")
  /// 人物名称
  name String @db.VarChar(128)
  /// 人物别名列表
  aliases String[] @default([])
  /// 人物角色定位
  role String? @db.VarChar(32)
  /// 身份设定
  identity String?
  /// 外貌描写
  appearance String?
  /// 性格描写
  personality String?
  /// 能力设定
  abilities String?
  /// 背景经历
  background String?
  /// 说话风格
  speakingStyle String? @map("speaking_style")
  /// 备注
  notes String?
  /// 来源类型：manual/imported/ai
  sourceType String @db.VarChar(16) @map("source_type")

  /// 删除标识
  deletedFlag Boolean @default(false) @map("deleted_flag")
  /// 创建时间
  createAt DateTime @db.Timestamptz(3) @default(now()) @map("create_at")
  /// 更新时间
  updateAt DateTime @updatedAt @db.Timestamptz(3) @map("update_at")

  @@index([userId])
  @@index([fandomId])
  @@index([novelId])
  @@index([fandomId, novelId, name])
  @@map("characters")
}
