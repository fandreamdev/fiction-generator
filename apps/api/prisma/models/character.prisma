enum CharacterSourceType {
  /// 手动创建
  MANUAL @map("manual")
  /// 导入抽取
  IMPORTED @map("imported")
  /// AI 生成
  AI @map("ai")

  @@map("character_source_type")
}

model Character {
  /// 主键
  id BigInt @id @default(autoincrement())
  /// 所属用户主键
  userId BigInt @map("user_id")
  /// 所属原作或世界观主键
  fandomId BigInt @map("fandom_id")
  /// 所属小说主键，可为空表示原作级人物
  novelId BigInt? @map("novel_id")
  /// 人物名称
  name String @db.VarChar(128)
  /// 人物别名列表
  aliases String[] @default([])
  /// 人物角色定位
  role String? @db.VarChar(32)
  /// 身份设定
  identity String?
  /// 外貌描写
  appearance String?
  /// 性格描写
  personality String?
  /// 能力设定
  abilities String?
  /// 背景经历
  background String?
  /// 说话风格
  speakingStyle String? @map("speaking_style")
  /// 备注
  notes String?
  /// 来源类型：manual/imported/ai
  sourceType CharacterSourceType @map("source_type")

  /// 删除标识
  deletedFlag Boolean @default(false) @map("deleted_flag")
  /// 创建时间
  createdAt DateTime @db.Timestamptz(3) @default(now()) @map("created_at")
  /// 更新时间
  updatedAt DateTime @updatedAt @db.Timestamptz(3) @map("updated_at")

  /// 所属用户
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// 所属原作或世界观
  fandom Fandom @relation(fields: [fandomId], references: [id], onDelete: Cascade)
  /// 所属小说
  novel Novel? @relation(fields: [novelId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([fandomId])
  @@index([novelId])
  @@index([fandomId, novelId, name])
  @@map("characters")
}
