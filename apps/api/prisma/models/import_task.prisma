enum ImportTaskSourceType {
  /// TXT 文件
  TXT @map("txt")
  /// Markdown 文件
  MARKDOWN @map("markdown")
  /// 粘贴文本
  PASTE @map("paste")

  @@map("import_task_source_type")
}

enum ImportTaskStatus {
  /// 等待处理
  PENDING @map("pending")
  /// 处理中
  PROCESSING @map("processing")
  /// 待审核
  REVIEWING @map("reviewing")
  /// 已完成
  COMPLETED @map("completed")
  /// 已失败
  FAILED @map("failed")

  @@map("import_task_status")
}

model ImportTask {
  /// 主键
  id BigInt @id @default(autoincrement())
  /// 所属用户主键
  userId BigInt @map("user_id")
  /// 所属原作或世界观主键
  fandomId BigInt @map("fandom_id")
  /// 导入文件名
  fileName String? @db.VarChar(256) @map("file_name")
  /// 来源类型：txt/markdown/paste
  sourceType ImportTaskSourceType @map("source_type")
  /// 任务状态：pending/processing/reviewing/completed/failed
  status ImportTaskStatus
  /// 任务进度，范围 0-100
  progress Int @default(0) @db.SmallInt
  /// 当前处理阶段：cleaning/splitting/summarizing/extracting/embedding
  stage String? @db.VarChar(32)
  /// 错误信息
  errorMessage String? @map("error_message")

  /// 删除标识
  deletedFlag Boolean @default(false) @map("deleted_flag")
  /// 创建时间
  createdAt DateTime @db.Timestamptz(3) @default(now()) @map("created_at")
  /// 更新时间
  updatedAt DateTime @updatedAt @db.Timestamptz(3) @map("updated_at")

  /// 所属用户
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// 所属原作或世界观
  fandom Fandom @relation(fields: [fandomId], references: [id], onDelete: Cascade)
  /// 导入任务拆分出的章节
  importedChapters ImportedChapter[]
  /// 导入任务产生的抽取候选项
  extractionCandidates ExtractionCandidate[]

  @@index([userId])
  @@index([fandomId])
  @@map("import_tasks")
}
