model ImportTask {
  /// 主键
  id BigInt @id @default(autoincrement())
  /// 所属用户主键
  userId BigInt @map("user_id")
  /// 所属原作或世界观主键
  fandomId BigInt @map("fandom_id")
  /// 导入文件名
  fileName String? @db.VarChar(256) @map("file_name")
  /// 来源类型：txt/markdown/paste
  sourceType String @db.VarChar(16) @map("source_type")
  /// 任务状态：pending/processing/reviewing/completed/failed
  status String @db.VarChar(16)
  /// 任务进度，范围 0-100
  progress Int @default(0) @db.SmallInt
  /// 当前处理阶段：cleaning/splitting/summarizing/extracting/embedding
  stage String? @db.VarChar(32)
  /// 错误信息
  errorMessage String? @map("error_message")

  /// 删除标识
  deletedFlag Boolean @default(false) @map("deleted_flag")
  /// 创建时间
  createAt DateTime @db.Timestamptz(3) @default(now()) @map("create_at")
  /// 更新时间
  updateAt DateTime @updatedAt @db.Timestamptz(3) @map("update_at")

  @@index([userId])
  @@index([fandomId])
  @@map("import_tasks")
}
