model WritingStyle {
  /// 主键
  id Int @id @default(autoincrement())
  /// 所属用户主键
  userId Int @map("user_id")
  /// 所属小说主键
  novelId Int @map("novel_id")
  /// 风格名称
  name String @db.VarChar(128)
  /// 风格描述
  description String?
  /// 语气风格
  tone String? @db.VarChar(128)
  /// 节奏风格
  pacing String? @db.VarChar(128)
  /// 对话风格
  dialogueStyle String? @map("dialogue_style")
  /// 描写风格
  descriptionStyle String? @map("description_style")
  /// 避免规则
  avoidRules String? @map("avoid_rules")

  /// 删除标识
  deletedFlag Boolean @default(false) @map("deleted_flag")
  /// 创建时间
  createdAt DateTime @db.Timestamptz(3) @default(now()) @map("created_at")
  /// 更新时间
  updatedAt DateTime @updatedAt @db.Timestamptz(3) @map("updated_at")

  /// 所属用户
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// 所属小说
  novel Novel @relation(fields: [novelId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([novelId])
  @@map("writing_styles")
}
