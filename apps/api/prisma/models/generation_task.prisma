enum GenerationTaskType {
  /// 导入任务
  IMPORT
  /// 摘要任务
  SUMMARY
  /// 抽取任务
  EXTRACT
  /// 章节生成任务
  GENERATE_CHAPTER
  /// 章节摘要生成任务
  GENERATE_CHAPTER_SUMMARY
  /// 向量化任务
  EMBEDDING

  @@map("generation_task_type")
}

enum GenerationTaskStatus {
  /// 等待执行
  PENDING @map("pending")
  /// 运行中
  RUNNING @map("running")
  /// 成功
  SUCCESS @map("success")
  /// 失败
  FAILED @map("failed")

  @@map("generation_task_status")
}

model GenerationTask {
  /// 主键
  id Int @id @default(autoincrement())
  /// 所属用户主键
  userId Int @map("user_id")
  /// 所属小说主键，可为空
  novelId Int? @map("novel_id")
  /// 所属章节主键，可为空
  chapterId Int? @map("chapter_id")
  /// 任务类型：IMPORT/SUMMARY/EXTRACT/GENERATE_CHAPTER/GENERATE_CHAPTER_SUMMARY/EMBEDDING
  taskType GenerationTaskType @map("task_type")
  /// 任务状态：pending/running/success/failed
  status GenerationTaskStatus
  /// 使用的模型名称
  modelName String? @db.VarChar(64) @map("model_name")
  /// 提示词文本
  promptText String? @map("prompt_text")
  /// 生成结果文本
  resultText String? @map("result_text")
  /// token 用量统计
  tokenUsage Json? @map("token_usage") @db.JsonB
  /// 错误信息
  errorMessage String? @map("error_message")

  /// 删除标识
  deletedFlag Boolean @default(false) @map("deleted_flag")
  /// 创建时间
  createdAt DateTime @db.Timestamptz(3) @default(now()) @map("created_at")
  /// 更新时间
  updatedAt DateTime @updatedAt @db.Timestamptz(3) @map("updated_at")

  /// 所属用户
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// 所属小说
  novel Novel? @relation(fields: [novelId], references: [id], onDelete: SetNull)
  /// 所属章节
  chapter Chapter? @relation(fields: [chapterId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([novelId])
  @@index([chapterId])
  @@map("generation_tasks")
}
