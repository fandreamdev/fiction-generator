enum FandomType {
  /// 小说原作
  NOVEL @map("novel")
  /// 动画原作
  ANIME @map("anime")
  /// 游戏原作
  GAME @map("game")
  /// 影视原作
  FILM @map("film")
  /// 其他类型
  OTHER @map("other")

  @@map("fandom_type")
}

model Fandom {
  /// 主键
  id Int @id @default(autoincrement())
  /// 所属用户主键
  userId Int @map("user_id")
  /// 原作或世界观名称
  name String @db.VarChar(128)
  /// 类型：novel/anime/game/film/other
  type FandomType
  /// 简介
  description String?
  /// 备注
  notes String?

  /// 删除标识
  deletedFlag Boolean @default(false) @map("deleted_flag")
  /// 创建时间
  createdAt DateTime @db.Timestamptz(3) @default(now()) @map("created_at")
  /// 更新时间
  updatedAt DateTime @updatedAt @db.Timestamptz(3) @map("updated_at")

  /// 所属用户
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// 基于该原作或世界观的小说
  novels Novel[]
  /// 该原作或世界观的导入任务
  importTasks ImportTask[]
  /// 该原作或世界观的导入章节
  importedChapters ImportedChapter[]
  /// 该原作或世界观的抽取候选项
  extractionCandidates ExtractionCandidate[]
  /// 该原作或世界观的人物设定
  characters Character[]
  /// 该原作或世界观的世界设定
  worldSettings WorldSetting[]
  /// 该原作或世界观的向量文档
  vectorDocuments VectorDocument[]

  @@index([userId])
  @@map("fandoms")
}
