enum FandomType {
  /// 小说原作
  NOVEL @map("novel")
  /// 动画原作
  ANIME @map("anime")
  /// 游戏原作
  GAME @map("game")
  /// 影视原作
  FILM @map("film")
  /// 其他类型
  OTHER @map("other")

  @@map("fandom_type")
}

model Fandom {
  /// 主键
  id BigInt @id @default(autoincrement())
  /// 所属用户主键
  userId BigInt @map("user_id")
  /// 原作或世界观名称
  name String @db.VarChar(128)
  /// 类型：novel/anime/game/film/other
  type FandomType
  /// 简介
  description String?
  /// 备注
  notes String?

  /// 删除标识
  deletedFlag Boolean @default(false) @map("deleted_flag")
  /// 创建时间
  createAt DateTime @db.Timestamptz(3) @default(now()) @map("create_at")
  /// 更新时间
  updateAt DateTime @updatedAt @db.Timestamptz(3) @map("update_at")

  @@index([userId])
  @@map("fandoms")
}
