enum VectorDocumentSourceType {
  /// 导入章节摘要
  IMPORTED_CHAPTER_SUMMARY
  /// 人物
  CHARACTER
  /// 世界设定
  WORLD_SETTING
  /// 章节摘要
  CHAPTER_SUMMARY
  /// 写作风格
  WRITING_STYLE

  @@map("vector_document_source_type")
}

model VectorDocument {
  /// 主键
  id BigInt @id @default(autoincrement())
  /// 所属用户主键
  userId BigInt @map("user_id")
  /// 所属原作或世界观主键，可为空
  fandomId BigInt? @map("fandom_id")
  /// 所属小说主键，可为空
  novelId BigInt? @map("novel_id")
  /// 来源类型：IMPORTED_CHAPTER_SUMMARY/CHARACTER/WORLD_SETTING/CHAPTER_SUMMARY/WRITING_STYLE
  sourceType VectorDocumentSourceType @map("source_type")
  /// 来源实体主键
  sourceId BigInt @map("source_id")
  /// 向量化文本块
  chunkText String @map("chunk_text")
  /// pgvector 向量数据
  embedding Unsupported("vector(1536)")?
  /// 向量元数据
  metadata Json? @db.JsonB

  /// 删除标识
  deletedFlag Boolean @default(false) @map("deleted_flag")
  /// 创建时间
  createdAt DateTime @db.Timestamptz(3) @default(now()) @map("created_at")
  /// 更新时间
  updatedAt DateTime @updatedAt @db.Timestamptz(3) @map("updated_at")

  /// 所属用户
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// 所属原作或世界观
  fandom Fandom? @relation(fields: [fandomId], references: [id], onDelete: SetNull)
  /// 所属小说
  novel Novel? @relation(fields: [novelId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([fandomId])
  @@index([novelId])
  @@index([userId, fandomId, sourceType])
  @@map("vector_documents")
}
