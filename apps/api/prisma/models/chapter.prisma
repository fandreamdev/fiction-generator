model Chapter {
  /// 主键
  id BigInt @id @default(autoincrement())
  /// 所属小说主键
  novelId BigInt @map("novel_id")
  /// 所属分卷主键
  volumeId BigInt @map("volume_id")
  /// 章节序号
  chapterNo Int @map("chapter_no")
  /// 章节标题
  title String @db.VarChar(256)
  /// 章节大纲
  outline String?
  /// 章节正文
  content String?
  /// 章节摘要
  summary String?
  /// 字数
  wordCount Int @default(0) @map("word_count")
  /// 章节状态：draft/generated/final
  status String @db.VarChar(16)

  /// 删除标识
  deletedFlag Boolean @default(false) @map("deleted_flag")
  /// 创建时间
  createAt DateTime @db.Timestamptz(3) @default(now()) @map("create_at")
  /// 更新时间
  updateAt DateTime @updatedAt @db.Timestamptz(3) @map("update_at")

  @@unique([novelId, chapterNo])
  @@index([novelId])
  @@index([volumeId])
  @@map("chapters")
}
