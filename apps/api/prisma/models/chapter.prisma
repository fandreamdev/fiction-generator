enum ChapterStatus {
  /// 草稿
  DRAFT @map("draft")
  /// 已生成
  GENERATED @map("generated")
  /// 定稿
  FINAL @map("final")

  @@map("chapter_status")
}

model Chapter {
  /// 主键
  id Int @id @default(autoincrement())
  /// 所属小说主键
  novelId Int @map("novel_id")
  /// 所属分卷主键
  volumeId Int @map("volume_id")
  /// 章节序号
  chapterNo Int @map("chapter_no")
  /// 章节标题
  title String @db.VarChar(256)
  /// 章节大纲
  outline String?
  /// 章节正文
  content String?
  /// 章节摘要
  summary String?
  /// 字数
  wordCount Int @default(0) @map("word_count")
  /// 章节状态：draft/generated/final
  status ChapterStatus

  /// 删除标识
  deletedFlag Boolean @default(false) @map("deleted_flag")
  /// 创建时间
  createdAt DateTime @db.Timestamptz(3) @default(now()) @map("created_at")
  /// 更新时间
  updatedAt DateTime @updatedAt @db.Timestamptz(3) @map("updated_at")

  /// 所属小说
  novel Novel @relation(fields: [novelId], references: [id], onDelete: Cascade)
  /// 所属分卷
  volume Volume @relation(fields: [volumeId], references: [id], onDelete: Cascade)
  /// 章节生成任务
  generationTasks GenerationTask[]

  @@unique([novelId, chapterNo])
  @@index([novelId])
  @@index([volumeId])
  @@map("chapters")
}
